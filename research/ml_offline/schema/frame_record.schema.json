{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tof3.local/schema/frame_record.schema.json",
  "title": "TOF3.0 Frame Record",
  "description": "One JSON object per line in ~/tof-data/sessions/<session_id>/frames.jsonl. Append-only.",
  "type": "object",
  "additionalProperties": false,
  "required": ["t", "seq", "laser"],
  "properties": {
    "t":   { "type": "string", "format": "date-time" },
    "seq": { "type": "integer", "minimum": 0, "description": "PF32 histogram seq" },

    "depth_path": {
      "type": ["string", "null"],
      "description": "Relative to session dir, e.g. depth/000123.tofrec"
    },
    "raw_path": {
      "type": ["string", "null"],
      "description": "Relative to session dir, e.g. raw/000123.tch; null when not kept"
    },
    "raw_kept_reason": {
      "type": ["string", "null"],
      "enum": ["q_outlier_high", "q_outlier_low", "manual", "scheduled_sample", "event_trigger", null],
      "description": "Why this frame's raw histogram was kept (null = not kept)"
    },

    "laser": {
      "type": "object",
      "additionalProperties": false,
      "required": ["level", "trigger_mode"],
      "properties": {
        "level":          { "type": "integer", "minimum": 0, "maximum": 200 },
        "pulse_width_ns": { "type": ["integer", "null"], "minimum": 5, "maximum": 200 },
        "trigger_mode":   { "type": "string", "enum": ["off", "internal", "external"] }
      }
    },
    "motor": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "focus_step":        { "type": ["integer", "null"] },
        "focus_distance_mm": { "type": ["number", "null"], "minimum": 0 }
      }
    },
    "quality": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "description": "Q tuple emitted by Level 0 physical algorithm; closed-loop reward source",
      "properties": {
        "sbr":             { "type": "number" },
        "peak_fwhm_bins":  { "type": "number", "minimum": 0 },
        "peak_skewness":   { "type": "number" },
        "residual_energy": { "type": "number", "minimum": 0 }
      }
    },
    "valid_count": { "type": ["integer", "null"], "minimum": 0, "maximum": 1024 },
    "tag":         { "type": ["string", "null"], "description": "Operator-marked event label, e.g. 'fog_burst_start'" }
  }
}
